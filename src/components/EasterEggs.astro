<div id="easter-egg-toast" role="status" aria-live="polite" aria-atomic="true">
</div>

<style>
  #easter-egg-toast {
    position: fixed;
    bottom: calc(1.5rem + env(safe-area-inset-bottom));
    right: calc(1.5rem + env(safe-area-inset-right));
    width: 320px;
    max-width: calc(100vw - 3rem);
    padding: 1.25rem 1.5rem;
    border-radius: var(--radius);
    background: var(--paper);
    border: 1px solid var(--rule);
    border-left: 3px solid var(--rule);
    box-shadow: var(--shadow-elevated);
    font-size: 1rem;
    line-height: 1.5;
    color: var(--ink);
    z-index: var(--z-toast);
    opacity: 0;
    transform: translateY(1rem);
    pointer-events: none;
    transition:
      opacity 0.3s ease,
      transform 0.3s ease;
  }

  #easter-egg-toast.visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  #easter-egg-toast[data-egg="socialist"] {
    border-left-color: var(--ink);
  }

  #easter-egg-toast[data-egg="buddhist"] {
    border-left-color: var(--ink-soft);
  }

  #easter-egg-toast[data-egg="antifascist"] {
    border-left: 5px solid var(--ink);
  }

  #easter-egg-toast[data-egg="artemis"] {
    border-left-color: var(--moss);
  }

  .easter-egg-icon {
    font-size: 1.5rem;
    line-height: 1;
    display: block;
    margin-bottom: 0.65rem;
  }

  .easter-egg-quote {
    font-family: var(--font-serif);
    font-style: italic;
    margin: 0 0 0.65rem;
    line-height: 1.45;
    text-wrap: pretty;
  }

  .easter-egg-attr {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    #easter-egg-toast {
      transition: opacity 0.15s ease;
      transform: none;
    }
  }
</style>

<script>
  const MARX = ["m", "a", "r", "x"];
  const BUDDHA = ["b", "u", "d", "d", "h", "a"];
  const DHARMA = ["d", "h", "a", "r", "m", "a"];
  const ANTIFA = ["a", "n", "t", "i", "f", "a"];
  const ARTEMIS = ["a", "r", "t", "e", "m", "i", "s"];

  const KONAMI = [
    "ArrowUp",
    "ArrowUp",
    "ArrowDown",
    "ArrowDown",
    "ArrowLeft",
    "ArrowRight",
    "ArrowLeft",
    "ArrowRight",
    "KeyB",
    "KeyA",
  ];

  type EggKey = "socialist" | "buddhist" | "antifascist" | "artemis";
  type EggData = {
    icon: string;
    quote: string;
    attr: string;
    consoleArt?: string[];
    consoleColor?: string;
  };

  const EGGS: Record<EggKey, EggData> = {
    socialist: {
      icon: "✊",
      quote:
        "From each according to his ability, to each according to his needs.",
      attr: "— Karl Marx",
    },
    buddhist: {
      icon: "☸",
      quote: "Peace comes from within. Do not seek it without.",
      attr: "— attributed to the Buddha",
      consoleArt: [
        "",
        "  ☸  Dharmachakra — The Wheel of Dharma",
        "",
        "            ╱ ┃ ╲",
        "          ╱   ┃   ╲",
        "        ╱     ┃     ╲",
        "      ━━━━━━━(☸)━━━━━━━",
        "        ╲     ┃     ╱",
        "          ╲   ┃   ╱",
        "            ╲ ┃ ╱",
        "",
        "  The Noble Eightfold Path:",
        "  Right View · Right Intention · Right Speech",
        "  Right Action · Right Livelihood · Right Effort",
        "  Right Mindfulness · Right Concentration",
        "",
      ],
      consoleColor: "#6b5d47",
    },
    antifascist: {
      icon: "🏴",
      quote: "Fascism is not to be debated, it is to be smashed.",
      attr: "— Buenaventura Durruti",
    },
    artemis: {
      icon: "🌕",
      quote:
        "Earth is the cradle of humanity, but one cannot live in a cradle forever.",
      attr: "— Konstantin Tsiolkovsky",
      consoleArt: [
        "",
        "  🌕  Artemis — Return to the Moon",
        "",
        "        *    .  *       .      ",
        "    .       *      .        *  ",
        "       .  ·  ☽  ·  .    .     ",
        "    *      .    .      *       ",
        "        .    *    .            ",
        "",
        "  Artemis II — First crewed lunar flyby",
        "  since Apollo 17, 1972.",
        "",
        "  Reid Wiseman · Victor Glover",
        "  Christina Koch · Jeremy Hansen",
        "",
      ],
      consoleColor: "#2a4a6b",
    },
  };

  type Sequence = [keys: string[], egg: EggKey, useCode: boolean];
  const SEQUENCES: Sequence[] = [
    [KONAMI, "socialist", true],
    [MARX, "socialist", false],
    [BUDDHA, "buddhist", false],
    [DHARMA, "buddhist", false],
    [ANTIFA, "antifascist", false],
    [ARTEMIS, "artemis", false],
  ];

  let toast: HTMLElement | undefined;
  let hideTimer: ReturnType<typeof setTimeout> | undefined;

  function showToast(egg: EggKey) {
    if (!toast) return;

    clearTimeout(hideTimer);

    const { icon, quote, attr } = EGGS[egg];
    toast.dataset.egg = egg;
    const iconEl = document.createElement("span");
    iconEl.className = "easter-egg-icon";
    iconEl.textContent = icon;
    const quoteEl = document.createElement("p");
    quoteEl.className = "easter-egg-quote";
    quoteEl.textContent = quote;
    const attrEl = document.createElement("p");
    attrEl.className = "easter-egg-attr";
    attrEl.textContent = attr;
    toast.replaceChildren(iconEl, quoteEl, attrEl);
    toast.classList.add("visible");

    const { consoleArt, consoleColor } = EGGS[egg];
    if (consoleArt) {
      console.log(
        "%c" + consoleArt.join("\n"),
        `color: ${consoleColor}; font-family: monospace; line-height: 1.6;`
      );
    }

    hideTimer = setTimeout(() => {
      toast?.classList.remove("visible");
    }, 4000);
  }

  function addLongPress(
    el: Element | null,
    onLongPress: () => void,
    duration = 600
  ) {
    if (!el) return;
    let timer: ReturnType<typeof setTimeout> | undefined;
    let startX = 0;
    let startY = 0;
    let fired = false;

    el.addEventListener(
      "touchstart",
      (ev) => {
        const touch = (ev as TouchEvent).touches[0];
        startX = touch.clientX;
        startY = touch.clientY;
        fired = false;
        timer = setTimeout(() => {
          fired = true;
          onLongPress();
        }, duration);
      },
      { passive: true }
    );

    el.addEventListener(
      "touchmove",
      (ev) => {
        if (timer === undefined) return;
        const touch = (ev as TouchEvent).touches[0];
        if (
          Math.abs(touch.clientX - startX) > 10 ||
          Math.abs(touch.clientY - startY) > 10
        ) {
          clearTimeout(timer);
          timer = undefined;
        }
      },
      { passive: true }
    );

    el.addEventListener("touchend", (ev) => {
      clearTimeout(timer);
      if (fired) ev.preventDefault();
    });
  }

  function addTripleSwipeLeft(el: Element | null, onTripleSwipe: () => void) {
    if (!el) return;
    let startX = 0;
    let swipeCount = 0;
    let resetTimer: ReturnType<typeof setTimeout> | undefined;

    el.addEventListener(
      "touchstart",
      (ev) => {
        startX = (ev as TouchEvent).touches[0].clientX;
      },
      { passive: true }
    );

    el.addEventListener("touchend", (ev) => {
      const endX = (ev as TouchEvent).changedTouches[0].clientX;
      if (startX - endX > 50) {
        swipeCount++;
        clearTimeout(resetTimer);
        if (swipeCount === 3) {
          swipeCount = 0;
          onTripleSwipe();
        } else {
          resetTimer = setTimeout(() => {
            swipeCount = 0;
          }, 1500);
        }
      }
    });
  }

  let initialized = false;

  function init() {
    toast =
      document.querySelector<HTMLElement>("#easter-egg-toast") ?? undefined;
    const footerEl = document.querySelector("footer");
    const headerEl = document.querySelector("header");
    const titleLink = document.querySelector("header a:first-child");

    if (!initialized) {
      initialized = true;

      const progress = SEQUENCES.map(() => 0);

      document.addEventListener("keydown", (e: KeyboardEvent) => {
        if (
          e.isComposing ||
          e.target instanceof HTMLInputElement ||
          e.target instanceof HTMLTextAreaElement
        )
          return;

        const key = e.key.toLowerCase();
        for (const [i, [seq, egg, useCode]] of SEQUENCES.entries()) {
          const input = useCode ? e.code : key;
          if (input === seq[progress[i]]) {
            progress[i]++;
            if (progress[i] === seq.length) {
              progress[i] = 0;
              showToast(egg);
            }
          } else {
            progress[i] = input === seq[0] ? 1 : 0;
          }
        }
      });
    }

    let clickCount = 0;
    let clickTimer: ReturnType<typeof setTimeout> | undefined;

    titleLink?.addEventListener("click", () => {
      clickCount++;
      if (clickCount === 3) {
        clickCount = 0;
        clearTimeout(clickTimer);
        showToast("buddhist");
        return;
      }
      clearTimeout(clickTimer);
      clickTimer = setTimeout(() => {
        clickCount = 0;
      }, 600);
    });

    addLongPress(titleLink, () => showToast("buddhist"));
    addLongPress(footerEl, () => showToast("socialist"));
    addTripleSwipeLeft(headerEl, () => showToast("antifascist"));
    addTripleSwipeLeft(footerEl, () => showToast("artemis"));
  }

  document.addEventListener("astro:page-load", init);
</script>
