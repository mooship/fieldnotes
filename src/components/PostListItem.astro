---
import { formatDate, getPostSlug } from "../lib/blog";

interface Props {
  post: {
    id: string;
    data: {
      title: string;
      description: string;
      pubDate: Date;
      tags: string[];
    };
  };
  readingTime?: string;
  showTags?: boolean;
}

const { post, readingTime, showTags = false } = Astro.props;
---

<li>
  <a
    class="post-title"
    href={`/blog/${getPostSlug(post.id)}`}
    transition:name={`post-title-${getPostSlug(post.id)}`}>{post.data.title}</a
  >
  <p class="post-meta meta-label">
    <time datetime={post.data.pubDate.toISOString()}>
      {formatDate(post.data.pubDate)}
    </time>
    {readingTime && <span> · {readingTime}</span>}
  </p>
  {
    showTags && post.data.tags.length > 0 && (
      <ul class="post-tags" aria-label="Tags">
        {post.data.tags.map((tag: string) => (
          <li>
            <a href={`/blog/tags/${tag}`} class="tag">
              {tag}
            </a>
          </li>
        ))}
      </ul>
    )
  }
  <p class="post-desc">{post.data.description}</p>
</li>

<style>
  li {
    margin-bottom: 1.5rem;
  }

  .post-title {
    font-size: 1.05rem;
    font-weight: 500;
  }

  .post-meta {
    margin: 0.35rem 0 0 0;
  }

  .post-tags {
    margin: 0.5rem 0;
  }

  .post-desc {
    margin: 0.25rem 0 0 0;
    font-size: 0.9375rem;
    color: var(--secondary-label);
    line-height: 1.47;
  }
</style>
