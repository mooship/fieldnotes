---
import type { CollectionEntry } from "astro:content";
import { formatDate, getPostSlug } from "../lib/blog";

interface Props {
  post: CollectionEntry<"blog">;
  readingTime?: string;
}

const { post, readingTime } = Astro.props;
const slug = getPostSlug(post.id);
---

<li>
  <p class="post-meta meta-label">
    <time datetime={post.data.pubDate.toISOString()}>
      {formatDate(post.data.pubDate)}
    </time>
    {readingTime && <span> · {readingTime}</span>}
  </p>
  <a class="post-title" href={`/blog/${slug}`}>{post.data.title}</a>
  <p class="post-desc">{post.data.description}</p>
</li>

<style>
  li {
    padding: 1.6rem 0;
    border-bottom: 1px solid var(--rule);
    margin-bottom: 0;
  }

  .post-meta {
    margin: 0;
  }

  .post-title {
    display: inline-block;
    margin-top: 0.4rem;
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  .post-desc {
    margin: 0.4rem 0 0 0;
    font-size: 0.9375rem;
    color: var(--ink-soft);
    line-height: 1.5;
  }
</style>
