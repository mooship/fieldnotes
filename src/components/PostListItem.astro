---
import { formatDate, getPostSlug } from "../lib/blog";

interface Props {
  post: {
    id: string;
    data: {
      title: string;
      description: string;
      pubDate: Date;
    };
  };
  readingTime?: string;
}

const { post, readingTime } = Astro.props;
const slug = getPostSlug(post.id);
---

<li>
  <a class="post-title" href={`/blog/${slug}`}>{post.data.title}</a>
  <p class="post-meta meta-label">
    <time datetime={post.data.pubDate.toISOString()}>
      {formatDate(post.data.pubDate)}
    </time>
    {readingTime && <span> · {readingTime}</span>}
  </p>
  <p class="post-desc">{post.data.description}</p>
</li>

<style>
  li {
    padding: 1.6rem 0;
    border-bottom: 1px solid var(--rule);
    margin-bottom: 0;
  }

  .post-title {
    font-size: 1.0625rem;
    font-weight: 500;
  }

  .post-meta {
    margin: 0.4rem 0 0 0;
  }

  .post-desc {
    margin: 0.4rem 0 0 0;
    font-size: 0.9375rem;
    color: var(--secondary-label);
    line-height: 1.5;
  }
</style>
