---

<span id="carbon-badge"></span>

<script>
  const KWH_PER_GB = 0.81;
  const GIGABYTE = 1024 * 1024 * 1024;
  const GLOBAL_GRID_INTENSITY = 494;
  const RENEWABLES_GRID_INTENSITY = 50;
  const FIRST_TIME_VIEWING_PERCENTAGE = 0.75;
  const RETURNING_VISITOR_PERCENTAGE = 0.25;
  const PERCENTAGE_OF_DATA_LOADED_ON_SUBSEQUENT_LOAD = 0.02;
  const DATACENTER_ENERGY_SHARE = 0.15;

  const CACHE_FACTOR =
    FIRST_TIME_VIEWING_PERCENTAGE +
    RETURNING_VISITOR_PERCENTAGE * PERCENTAGE_OF_DATA_LOADED_ON_SUBSEQUENT_LOAD;
  const GREEN_GRID_INTENSITY =
    DATACENTER_ENERGY_SHARE * RENEWABLES_GRID_INTENSITY +
    (1 - DATACENTER_ENERGY_SHARE) * GLOBAL_GRID_INTENSITY;

  /**
   * Estimate grams of CO₂ per page view from transferred bytes using the
   * Sustainable Web Design Model (the same model the Website Carbon
   * Calculator uses). Computed client-side so the badge renders identically
   * in dev, preview, and production with no runtime API dependency.
   */
  function estimateGramsCo2(bytes: number): number {
    const energyKwh = (bytes / GIGABYTE) * KWH_PER_GB * CACHE_FACTOR;
    return energyKwh * GREEN_GRID_INTENSITY;
  }

  function measureBytes(): number {
    const nav = performance.getEntriesByType("navigation")[0] as
      | PerformanceNavigationTiming
      | undefined;
    let bytes = nav
      ? nav.encodedBodySize || nav.decodedBodySize || nav.transferSize || 0
      : 0;
    for (const r of performance.getEntriesByType(
      "resource"
    ) as PerformanceResourceTiming[]) {
      bytes += r.encodedBodySize || r.decodedBodySize || 0;
    }
    return bytes;
  }

  function render() {
    const el = document.querySelector<HTMLElement>("#carbon-badge");
    if (!el) {
      return;
    }

    const gco2e = estimateGramsCo2(measureBytes());
    const grams = gco2e < 0.005 ? "<0.01" : gco2e.toFixed(2);

    const a = document.createElement("a");
    a.href = "https://sustainablewebdesign.org/estimating-digital-emissions/";
    a.rel = "noopener noreferrer";
    a.title =
      "Estimated emissions per page view — Sustainable Web Design Model";
    a.textContent = `${grams} g CO₂/view`;
    el.replaceChildren(a);
  }

  if (document.readyState === "complete") {
    render();
  } else {
    window.addEventListener("load", render, { once: true });
  }
</script>
