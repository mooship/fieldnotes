---
import Layout from "../layouts/Layout.astro";
import { Content as NowContent, frontmatter as nowFrontmatter } from "../sections/now.md";
import { SITE_TITLE } from "../lib/blog";

const lastUpdated = new Date(nowFrontmatter.lastUpdated as string);
const lastUpdatedDisplay = lastUpdated.toLocaleDateString("en-ZA", {
  year: "numeric",
  month: "long",
});
const lastUpdatedDatetime = lastUpdated.toISOString().slice(0, 7);
---

<Layout
  title={`Now — ${SITE_TITLE}`}
  description="What I'm currently working on, reading, and learning."
  type="website"
>
  <main id="main-content" tabindex="-1">
    <h1 class="page-title">Now</h1>
    <p class="meta-label updated">
      Last updated: <time datetime={lastUpdatedDatetime}>{lastUpdatedDisplay}</time>
    </p>
    <NowContent />
    <p class="nownownow">
      This is a <a href="https://nownownow.com/about">now page</a>.
    </p>
    <a href="/" class="nav-link back-link">
      <span aria-hidden="true">&larr;</span> Back
    </a>
  </main>
</Layout>

<style>
  main {
    margin: auto;
    padding-top: 2rem;
  }

  .page-title {
    margin-bottom: 0.5rem;
  }

  .updated {
    margin: 0 0 2rem 0;
  }

  main :global(p) {
    line-height: 1.6;
    margin: 0 0 1rem 0;
  }

  main :global(ul) {
    padding-left: 1.5rem;
    list-style: disc;
    margin-top: 0;
  }

  main :global(li) {
    margin-bottom: 0.4rem;
    color: var(--label);
  }

  .nownownow {
    font-size: 0.85rem;
    color: var(--secondary-label);
    margin-top: 2rem;
  }

  .back-link {
    margin-top: 1rem;
  }
</style>
