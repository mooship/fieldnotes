---
import Layout from "../layouts/Layout.astro";
import { SITE_TITLE } from "../lib/blog";
---

<Layout title={`Page not found — ${SITE_TITLE}`} robots="noindex">
  <main id="main-content" tabindex="-1">
    <h1 class="page-title">404</h1>
    <p>This page doesn't exist.</p>
    <nav class="links" aria-label="Suggested pages">
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/blog">Blog</a></li>
        <li><a href="/now">Now</a></li>
        <li><a href="/uses">Uses</a></li>
      </ul>
    </nav>
  </main>
</Layout>

<style>
  main {
    margin: auto;
    padding-top: 2rem;
  }

  .page-title {
    font-size: 4rem;
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  p {
    color: var(--ink-soft);
    font-size: 0.95rem;
    margin: 0 0 1.5rem 0;
  }

  .links ul {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .links a {
    font-size: 0.95rem;
  }
</style>
