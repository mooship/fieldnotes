---
import PostListItem from "../../../components/PostListItem.astro";
import Layout from "../../../layouts/Layout.astro";
import {
  computeReadingTime,
  getAllTags,
  getBlogPosts,
  getPostsByTag,
  SITE_TITLE,
} from "../../../lib/blog";

export async function getStaticPaths() {
  const posts = await getBlogPosts();
  const tags = getAllTags(posts);

  return tags.map((tag) => ({
    params: { tag },
    props: { tag, posts: getPostsByTag(posts, tag) },
  }));
}

const { tag, posts } = Astro.props;
const postsWithMeta = posts.map((post) => ({
  post,
  readingTime: computeReadingTime(post.body),
}));
---

<Layout
  title={`Posts tagged "${tag}" — ${SITE_TITLE}`}
  description={`Blog posts tagged "${tag}".`}
  type="website"
>
  <main id="main-content" tabindex="-1">
    <a href="/blog" class="nav-link back-link">
      <span aria-hidden="true">&larr;</span> All posts
    </a>
    <h1 class="page-title">Tagged &ldquo;{tag}&rdquo;</h1>
    <ul>
      {
        postsWithMeta.map(({ post, readingTime }) => (
          <PostListItem post={post} readingTime={readingTime} />
        ))
      }
    </ul>
  </main>
</Layout>

<style>
  main {
    margin: auto;
    padding-top: 2rem;
  }

  .back-link {
    margin-bottom: 2rem;
  }

  ul {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem 0;
  }
</style>
