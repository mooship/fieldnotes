---
import Layout from "../../../layouts/Layout.astro";
import {
  formatDate,
  getBlogPosts,
  getPostSlug,
  SITE_TITLE,
} from "../../../lib/blog";

const posts = await getBlogPosts();
const grouped = new Map<string, typeof posts>();
for (const post of posts) {
  if (!post.data.series) continue;
  const bucket = grouped.get(post.data.series) ?? [];
  bucket.push(post);
  grouped.set(post.data.series, bucket);
}
const series = [...grouped.entries()]
  .toSorted(([a], [b]) => a.localeCompare(b))
  .map(([name, seriesPosts]) => ({
    name,
    posts: seriesPosts.toSorted((a, b) => {
      const orderA = a.data.seriesOrder ?? Infinity;
      const orderB = b.data.seriesOrder ?? Infinity;
      if (orderA !== orderB) return orderA - orderB;
      return a.data.pubDate.valueOf() - b.data.pubDate.valueOf();
    }),
  }));
---

<Layout
  title={`Series — ${SITE_TITLE}`}
  description="Multi-part blog post series."
  type="website"
>
  <main id="main-content" tabindex="-1">
    <a href="/blog" class="nav-link back-link">
      <span aria-hidden="true">&larr;</span> All posts
    </a>
    <h1 class="page-title">Series</h1>
    {
      series.length === 0 ? (
        <p class="empty">No series yet.</p>
      ) : (
        <div class="series-list">
          {series.map(({ name, posts: seriesPosts }) => (
            <section class="series-section">
              <h2>{name}</h2>
              <ol>
                {seriesPosts.map((post) => (
                  <li>
                    <a href={`/blog/${getPostSlug(post.id)}`}>
                      {post.data.title}
                    </a>
                    <time
                      class="meta-label post-date"
                      datetime={post.data.pubDate.toISOString()}
                    >
                      {formatDate(post.data.pubDate)}
                    </time>
                  </li>
                ))}
              </ol>
            </section>
          ))}
        </div>
      )
    }
  </main>
</Layout>

<style>
  main {
    margin: auto;
    padding-top: 2rem;
  }

  .back-link {
    margin-bottom: 2rem;
  }

  .empty {
    color: var(--ink-soft);
    font-size: 0.95rem;
  }

  .series-list {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .series-section {
    padding-top: 2rem;
    border-top: 1px solid var(--rule);
  }

  .series-section:first-child {
    padding-top: 0;
    border-top: none;
  }

  .series-section h2 {
    font-family: var(--font-serif);
    font-size: 1.375rem;
    font-weight: 400;
    margin: 0 0 0.875rem 0;
    letter-spacing: -0.01em;
  }

  .series-section ol {
    list-style: decimal;
    padding-left: 1.25rem;
    margin: 0;
  }

  .series-section li {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
    font-size: 0.95rem;
  }

  .series-section a {
    font-family: var(--font-serif);
  }

  .post-date {
    flex-shrink: 0;
    color: var(--ink-soft);
  }
</style>
