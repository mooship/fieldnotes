---
import { render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { ArrowLeft, ArrowRight } from "@lucide/astro";
import {
  formatDate,
  getAdjacentPosts,
  getBlogPosts,
  getPostSlug,
  getReadingTime,
  getRelatedPosts,
  getSeriesPosts,
  SITE_TITLE,
} from "../../lib/blog";

export async function getStaticPaths() {
  const posts = await getBlogPosts();
  return posts.map((post) => {
    const slug = getPostSlug(post.id);
    const adjacent = getAdjacentPosts(posts, slug);
    const related = getRelatedPosts(posts, post);
    const seriesPosts = post.data.series
      ? getSeriesPosts(posts, post.data.series)
      : [];
    return {
      params: { slug },
      props: { post, adjacent, related, seriesPosts },
    };
  });
}

const { post, adjacent, related, seriesPosts } = Astro.props;
const { slug } = Astro.params;
const { Content, remarkPluginFrontmatter } = await render(post);
const readingTime = getReadingTime(remarkPluginFrontmatter);
const ogImage = new URL(`/og/${slug}.png`, Astro.site).toString();
---

<Layout
  title={`${post.data.title} — ${SITE_TITLE}`}
  description={post.data.description}
  image={ogImage}
  type="article"
  datePublished={post.data.pubDate}
  dateModified={post.data.updatedDate ?? post.data.pubDate}
>
  <main id="main-content" tabindex="-1">
    <a href="/blog" class="nav-link back-link">
      <span aria-hidden="true">&larr;</span> All posts
    </a>
    <article>
      <header>
        <h1>{post.data.title}</h1>
        <time class="meta-label" datetime={post.data.pubDate.toISOString()}>
          <span class="visually-hidden">Published: </span>
          {formatDate(post.data.pubDate)}
        </time>
        {
          readingTime && (
            <span class="meta-label reading-time">{readingTime}</span>
          )
        }
        {
          post.data.updatedDate && (
            <time
              class="meta-label updated"
              datetime={post.data.updatedDate.toISOString()}
            >
              Updated: {formatDate(post.data.updatedDate)}
            </time>
          )
        }
        {
          post.data.tags.length > 0 && (
            <ul class="post-tags" aria-label="Tags">
              {post.data.tags.map((tag: string) => (
                <li>
                  <a href={`/blog/tags/${tag}`} class="tag">
                    {tag}
                  </a>
                </li>
              ))}
            </ul>
          )
        }
      </header>
      {
        seriesPosts.length > 1 && (
          <nav class="series-box" aria-label="Post series">
            <p class="meta-label series-label">
              Series: <strong>{post.data.series}</strong>
            </p>
            <ol>
              {seriesPosts.map(
                (sp: { id: string; data: { title: string } }) => {
                  const spSlug = getPostSlug(sp.id);
                  const isCurrent = sp.id === post.id;
                  return (
                    <li class={isCurrent ? "current" : ""}>
                      {isCurrent ? (
                        <span aria-current="page">{sp.data.title}</span>
                      ) : (
                        <a href={`/blog/${spSlug}`}>{sp.data.title}</a>
                      )}
                    </li>
                  );
                }
              )}
            </ol>
          </nav>
        )
      }
      <Content />
    </article>
    <div class="post-footer">
      <button
        class="share-btn"
        type="button"
        aria-live="polite"
        aria-label="Share this post"
        data-title={post.data.title}
      >
        Share
      </button>
    </div>
    {
      related.length > 0 && (
        <aside class="related-posts">
          <h2 class="meta-label">Related posts</h2>
          <ul>
            {related.map(
              (rp: { id: string; data: { title: string; pubDate: Date } }) => (
                <li>
                  <a href={`/blog/${getPostSlug(rp.id)}`}>{rp.data.title}</a>
                </li>
              )
            )}
          </ul>
        </aside>
      )
    }
    {
      (adjacent.prev || adjacent.next) && (
        <nav class="post-nav" aria-label="Post navigation">
          {adjacent.prev ? (
            <a href={`/blog/${adjacent.prev.slug}`} class="post-nav-link prev">
              <ArrowLeft size={16} aria-hidden="true" />
              <span>{adjacent.prev.title}</span>
            </a>
          ) : (
            <span />
          )}
          {adjacent.next ? (
            <a href={`/blog/${adjacent.next.slug}`} class="post-nav-link next">
              <span>{adjacent.next.title}</span>
              <ArrowRight size={16} aria-hidden="true" />
            </a>
          ) : (
            <span />
          )}
        </nav>
      )
    }
  </main>
</Layout>

<script>
  function initCopyButtons() {
    for (const pre of document.querySelectorAll("article pre")) {
      if (pre.querySelector(".copy-btn")) continue;

      const button = document.createElement("button");
      button.className = "copy-btn";
      button.type = "button";
      button.setAttribute("aria-label", "Copy code");
      button.setAttribute("aria-live", "polite");
      button.textContent = "Copy";

      let resetTimer: ReturnType<typeof setTimeout> | undefined;
      button.addEventListener("click", async () => {
        const code = pre.querySelector("code");
        if (!code) return;

        clearTimeout(resetTimer);
        try {
          await navigator.clipboard.writeText(code.textContent ?? "");
          button.textContent = "Copied!";
        } catch {
          button.textContent = "Failed";
        }
        resetTimer = setTimeout(() => {
          button.textContent = "Copy";
        }, 2000);
      });

      (pre as HTMLElement).style.position = "relative";
      pre.append(button);
    }
  }

  function initShareButton() {
    const btn = document.querySelector<HTMLButtonElement>(".share-btn");
    if (!btn) return;

    const canShare = "share" in navigator;
    const canCopy = "clipboard" in navigator;
    if (!canShare && !canCopy) {
      btn.hidden = true;
      return;
    }

    const shareData = {
      title: btn.dataset.title ?? document.title,
      url: globalThis.location.href,
    };

    let resetTimer: ReturnType<typeof setTimeout> | undefined;
    btn.addEventListener("click", async () => {
      if (canShare && navigator.canShare?.(shareData)) {
        try {
          await navigator.share(shareData);
          return;
        } catch (error) {
          if (error instanceof DOMException && error.name === "AbortError")
            return;
          // share failed for another reason — fall through to clipboard
        }
      }
      clearTimeout(resetTimer);
      try {
        await navigator.clipboard.writeText(shareData.url);
        btn.textContent = "Copied!";
      } catch {
        btn.textContent = "Failed";
      }
      resetTimer = setTimeout(() => {
        btn.textContent = "Share";
      }, 2000);
    });
  }

  document.addEventListener("DOMContentLoaded", () => {
    initCopyButtons();
    initShareButton();
  });
</script>

<style>
  main {
    margin: auto;
    padding-top: 2rem;
  }

  .back-link {
    margin-bottom: 2.5rem;
  }

  header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--rule);
  }

  h1 {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 2.375rem;
    margin: 0 0 0.75rem 0;
    letter-spacing: -0.015em;
    line-height: 1.12;
  }

  .updated {
    margin-top: 0.25rem;
  }

  .post-tags {
    margin-top: 0.75rem;
  }

  .post-footer {
    margin-top: 2.5rem;
  }

  .share-btn {
    background: none;
    border: 1px solid var(--rule);
    border-radius: var(--radius);
    padding: 0.45rem 1rem;
    font-family: var(--font-sans), system-ui, sans-serif;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-soft);
    cursor: pointer;
    transition:
      color 0.15s ease,
      border-color 0.15s ease;
  }

  .share-btn:hover {
    color: var(--link);
    border-color: var(--link);
  }

  .share-btn:focus-visible {
    outline: 2px solid var(--link);
    outline-offset: 2px;
  }

  article :global(p) {
    margin: 0 0 1.25rem 0;
    line-height: 1.65;
  }

  article :global(h2),
  article :global(h3),
  article :global(h4) {
    color: var(--ink);
    font-family: var(--font-serif);
    font-weight: 400;
    margin: 2.5rem 0 0.75rem 0;
    text-wrap: balance;
    letter-spacing: -0.005em;
    line-height: 1.2;
  }

  article :global(h2) {
    font-size: 1.5rem;
  }

  article :global(h3) {
    font-size: 1.25rem;
    font-style: italic;
    font-weight: 400;
  }

  article :global(h4) {
    font-size: 1.125rem;
  }

  article :global(blockquote) {
    margin: 1.75rem 0 1.75rem 1.5rem;
    padding: 0;
    color: var(--ink-soft);
    font-size: 1.05rem;
    font-style: italic;
  }

  article :global(blockquote) :global(p:last-child) {
    margin-bottom: 0;
  }

  article :global(code) {
    font-family: var(--font-mono), ui-monospace, monospace;
    font-size: 0.85em;
    background: var(--paper-deep);
    padding: 0.15em 0.4em;
    border-radius: var(--radius);
  }

  article :global(pre) {
    font-family: var(--font-mono), ui-monospace, monospace;
    background: var(--paper-deep);
    padding: 1.25rem;
    border-radius: var(--radius);
    border: 1px solid var(--rule);
    overflow-x: auto;
    margin: 1.5rem 0;
    font-size: 0.9rem;
    line-height: 1.6;
  }

  article :global(pre code) {
    background: none;
    padding: 0;
  }

  article :global(.copy-btn) {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    background: var(--paper);
    border: 1px solid var(--rule);
    border-radius: var(--radius);
    padding: 0.4rem 0.6rem;
    font-family: var(--font-sans), system-ui, sans-serif;
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-soft);
    cursor: pointer;
    opacity: 0.6;
    transition:
      opacity 0.2s ease,
      color 0.2s ease;
  }

  article :global(pre:hover .copy-btn),
  article :global(.copy-btn:focus-visible) {
    opacity: 1;
  }

  article :global(.copy-btn:focus-visible) {
    outline: 2px solid var(--tint);
    outline-offset: 2px;
  }

  article :global(.copy-btn:hover) {
    color: var(--label);
  }

  @media (pointer: coarse) {
    article :global(.copy-btn) {
      opacity: 1;
    }
  }

  article :global(ul),
  article :global(ol) {
    padding-left: 1.5rem;
    margin: 0 0 1rem 0;
  }

  article :global(li) {
    margin-bottom: 0.4rem;
    line-height: 1.47;
  }

  article :global(hr) {
    border: none;
    border-top: 1px solid var(--rule);
    margin: 2.5rem 0;
  }

  .series-box {
    border: 1px solid var(--rule);
    border-radius: var(--radius);
    padding: 1rem 1.25rem;
    margin-bottom: 2rem;
    background: var(--paper-deep);
  }

  .series-label {
    margin: 0 0 0.5rem 0;
  }

  .series-box ol {
    list-style: decimal;
    padding-left: 1.25rem;
    margin: 0;
  }

  .series-box li {
    font-size: 0.95rem;
    margin-bottom: 0.25rem;
    color: var(--ink-soft);
  }

  .series-box li.current {
    color: var(--ink);
    font-weight: 400;
    font-style: italic;
  }

  .related-posts {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--rule);
  }

  .related-posts h2 {
    margin: 0 0 0.75rem 0;
  }

  .related-posts ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .related-posts li {
    margin-bottom: 0.4rem;
  }

  .related-posts a {
    font-family: var(--font-serif);
    font-size: 1rem;
  }

  .post-nav {
    display: flex;
    justify-content: space-between;
    gap: 1.5rem;
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--rule);
  }

  .post-nav-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.95rem;
    font-style: italic;
    max-width: 48%;
  }

  .post-nav-link.next {
    margin-left: auto;
    text-align: right;
  }
</style>
