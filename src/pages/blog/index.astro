---
import Search from "astro-pagefind/components/Search";
import PostListItem from "../../components/PostListItem.astro";
import Layout from "../../layouts/Layout.astro";
import {
  BLOG_DESCRIPTION,
  computeReadingTime,
  getBlogPosts,
  SITE_TITLE,
} from "../../lib/blog";

const posts = await getBlogPosts();
const postsWithMeta = posts.map((post) => ({
  post,
  readingTime: computeReadingTime(post.body),
}));
---

<Layout
  title={`Blog — ${SITE_TITLE}`}
  description={BLOG_DESCRIPTION}
  type="website"
>
  <main id="main-content" tabindex="-1">
    <h1 class="page-title">Blog</h1>
    <div class="search-wrapper">
      <Search
        id="search"
        className="pagefind-ui"
        uiOptions={{ showImages: false, showSubResults: false }}
      />
    </div>
    {
      postsWithMeta.length === 0 ? (
        <p class="empty">No posts yet.</p>
      ) : (
        <ul>
          {postsWithMeta.map(({ post, readingTime }) => (
            <PostListItem post={post} readingTime={readingTime} showTags />
          ))}
        </ul>
      )
    }
    <a href="/" class="nav-link back-link">
      <span aria-hidden="true">&larr;</span> Back
    </a>
  </main>
</Layout>

<style>
  main {
    margin: auto;
    padding-top: 2rem;
  }

  ul {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem 0;
  }

  .empty {
    color: var(--secondary-label);
    font-size: 0.95rem;
  }

  .back-link {
    margin-top: 1rem;
  }

  .search-wrapper {
    margin-bottom: 2rem;
  }

  .search-wrapper :global(.pagefind-ui) {
    --pagefind-ui-scale: 0.85;
    --pagefind-ui-primary: var(--link);
    --pagefind-ui-text: var(--label);
    --pagefind-ui-background: var(--system-background);
    --pagefind-ui-border: var(--separator);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: var(--radius-input);
    --pagefind-ui-font: var(--font-sans), system-ui, sans-serif;
  }
</style>
