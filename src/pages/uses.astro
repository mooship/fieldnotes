---
import Layout from "../layouts/Layout.astro";
import { Content as UsesContent } from "../sections/uses.md";
import { SITE_TITLE } from "../lib/blog";
---

<Layout
  title={`Uses — ${SITE_TITLE}`}
  description="The tools, hardware, and software I use daily."
  type="website"
>
  <main id="main-content" tabindex="-1">
    <h1 class="page-title">Uses</h1>
    <UsesContent />
    <a href="/" class="nav-link back-link">
      <span aria-hidden="true">&larr;</span> Back
    </a>
  </main>
</Layout>

<style>
  main {
    margin: auto;
    padding-top: 2rem;
  }

  main :global(ul) {
    padding-left: 1.5rem;
    list-style: disc;
    margin-top: 0;
  }

  main :global(li) {
    margin-bottom: 0.4rem;
    color: var(--label);
  }

  .back-link {
    margin-top: 2rem;
  }
</style>
