---
import Layout from "../layouts/Layout.astro";
import { Content as IntroContent } from "../sections/intro.md";
import { Content as WritingContent } from "../sections/writing.md";
import { Content as OpenSourceContent } from "../sections/opensource.md";
import { Content as SupportContent } from "../sections/support.md";
import { formatDate, getBlogPosts, getPostSlug, SITE_TITLE } from "../lib/blog";

const posts = await getBlogPosts();
const recentPosts = posts.slice(0, 5);
---

<Layout
  title={SITE_TITLE}
  description="Personal site and blog of Timothy Brits — software, open source, and recent writing."
  type="website"
>
  <main id="main-content" tabindex="-1">
    <h1 class="visually-hidden">{SITE_TITLE}</h1>
    <div class="lead">
      <IntroContent />
    </div>
    {
      recentPosts.length > 0 && (
        <>
          <h2>Blog</h2>
          <ul class="recent-posts">
            {recentPosts.map((post) => (
              <li>
                <a href={`/blog/${getPostSlug(post.id)}`}>{post.data.title}</a>
                <time
                  class="meta-label post-date"
                  datetime={post.data.pubDate.toISOString()}
                >
                  {formatDate(post.data.pubDate)}
                </time>
              </li>
            ))}
          </ul>
          <a href="/blog" class="nav-link all-posts">
            All posts <span aria-hidden="true">&rarr;</span>
          </a>
        </>
      )
    }
    <OpenSourceContent />
    <WritingContent />
    <SupportContent />
  </main>
</Layout>

<style>
  main {
    margin: auto;
  }

  .lead :global(p) {
    color: var(--ink);
    margin-bottom: 3rem;
    font-size: 1.3125rem;
    font-weight: 400;
    font-style: italic;
    line-height: 1.5;
    letter-spacing: 0;
    text-wrap: balance;
  }

  main :global(h2) {
    font-size: 1.625rem;
    letter-spacing: -0.01em;
    margin-top: 3.5rem;
  }

  main :global(h2) + :global(p) {
    color: var(--ink-soft);
    margin-top: 0;
    margin-bottom: 0;
    font-size: 1rem;
  }

  main :global(ul) {
    list-style: none;
    padding: 0;
    margin: 1rem 0 0 0;
  }

  main :global(li) {
    margin-bottom: 0.5rem;
  }

  main :global(a) {
    font-size: 1.0625rem;
  }

  main :global(.project-desc) {
    margin: 0.1rem 0 0 0;
    font-size: 0.9rem;
    font-style: italic;
    color: var(--ink-soft);
    line-height: 1.5;
  }

  .recent-posts {
    list-style: none;
    padding: 0;
    margin: 1rem 0 1rem 0;
  }

  .recent-posts li {
    margin-bottom: 0.85rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
</style>
