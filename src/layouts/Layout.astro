---
import "../styles/tokens.css";
import "../styles/base.css";
import "../styles/typography.css";
import "../styles/code.css";
import { Font } from "astro:assets";
import CarbonBadge from "../components/CarbonBadge.astro";
import { SITE_AUTHOR, SITE_TITLE } from "../lib/blog";

export interface Props {
  title: string;
  description?: string;
  image?: string;
  canonical?: string;
  robots?: string;
  type?: "website" | "article";
  datePublished?: Date;
  dateModified?: Date;
}

const {
  title,
  description,
  image,
  canonical: canonicalProp,
  robots = "index,follow",
  type = "website",
  datePublished,
  dateModified,
} = Astro.props as Props;

const url = Astro.url;
const pathname = url.pathname;
const canonical = canonicalProp ?? url.origin + url.pathname;
const schemaType = type === "article" ? "Article" : "WebSite";
const jsonLd = {
  "@context": "https://schema.org",
  "@type": schemaType,
  name: type === "website" ? SITE_TITLE : title,
  ...(canonical ? { url: canonical } : {}),
  ...(description ? { description } : {}),
  ...(image ? { image } : {}),
  ...(type === "article"
    ? {
        author: { "@type": "Person", name: SITE_AUTHOR },
        ...(datePublished
          ? { datePublished: datePublished.toISOString() }
          : {}),
        ...(dateModified ? { dateModified: dateModified.toISOString() } : {}),
      }
    : {}),
};
---

<!doctype html>
<html lang="en">
  <head>
    <Font cssVariable="--font-sans" preload />
    <Font cssVariable="--font-mono" />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, viewport-fit=cover" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {canonical && <link rel="canonical" href={canonical} />}
    <meta name="robots" content={robots} />
    <meta
      name="theme-color"
      content="#ffffff"
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content="#0a0a0a"
      media="(prefers-color-scheme: dark)"
    />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${SITE_TITLE} — RSS`}
      href="/rss.xml"
    />
    <link
      rel="alternate"
      type="application/atom+xml"
      title={`${SITE_TITLE} — Atom`}
      href="/atom.xml"
    />
    <link
      rel="alternate"
      type="application/feed+json"
      title={`${SITE_TITLE} — JSON Feed`}
      href="/feed.json"
    />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content={type} />
    {canonical && <meta property="og:url" content={canonical} />}
    <meta property="og:site_name" content={SITE_TITLE} />
    <meta property="og:locale" content="en_ZA" />
    {image && <meta property="og:image" content={image} />}
    <meta
      name="twitter:card"
      content={image ? "summary_large_image" : "summary"}
    />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    {image && <meta name="twitter:image" content={image} />}
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(jsonLd)}
    />
  </head>
  <body>
    <a href="#main-content" class="skip-link visually-hidden"
      >Skip to main content</a
    >
    <header>
      <div class="masthead">
        <a href="/" class="wordmark">
          <span class="wordmark-mark" aria-hidden="true"></span>
          <span class="wordmark-title">{SITE_TITLE}</span>
          <span class="wordmark-byline">by {SITE_AUTHOR}</span>
        </a>
        <nav aria-label="Main">
          <a
            href="/blog"
            aria-current={pathname.startsWith("/blog") ? "page" : undefined}
            >Blog</a
          >
          <a href="/now" aria-current={pathname === "/now" ? "page" : undefined}
            >Now</a
          >
          <a
            href="/uses"
            aria-current={pathname === "/uses" ? "page" : undefined}>Uses</a
          >
        </nav>
      </div>
    </header>
    <slot />
    <footer>
      <nav class="feed-links" aria-label="Feed subscriptions">
        <span>Subscribe:</span>
        <a href="/atom.xml">Atom</a>
        <a href="/rss.xml">RSS</a>
        <a href="/feed.json">JSON Feed</a>
      </nav>
      <CarbonBadge />
    </footer>
  </body>
</html>

<style>
  .skip-link:focus-visible {
    position: fixed;
    top: 1rem;
    left: 1rem;
    width: auto;
    height: auto;
    clip-path: none;
    margin: 0;
    overflow: visible;
    white-space: normal;
    padding: 0.5rem 1rem;
    background: var(--paper);
    color: var(--link);
    border: 2px solid var(--link);
    border-radius: var(--radius);
    font-size: 0.9rem;
    z-index: var(--z-skip-link);
    text-decoration: none;
  }

  header {
    margin-bottom: 3.2rem;
  }

  .masthead {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.8rem 1.6rem;
    padding: 1.2rem 0 1.6rem 0;
    border-top: 4px solid var(--ink);
    border-bottom: 1px solid var(--rule);
  }

  .wordmark {
    display: grid;
    grid-template-columns: auto 1fr;
    column-gap: 0.5rem;
    row-gap: 0.25rem;
    align-items: center;
    text-decoration: none;
  }

  .wordmark:hover {
    text-decoration: none;
  }

  .wordmark-mark {
    width: 0.9rem;
    height: 0.9rem;
    background: var(--signal);
  }

  .wordmark-title {
    grid-column: 2;
    font-family: var(--font-sans);
    font-style: normal;
    font-weight: 700;
    font-size: 1.5rem;
    color: var(--ink);
    letter-spacing: -0.01em;
    line-height: 1;
  }

  .wordmark-byline {
    grid-column: 2;
    font-family: var(--font-sans);
    font-style: normal;
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-meta);
    color: var(--ink-soft);
    line-height: 1;
  }

  nav {
    display: flex;
    align-items: center;
    gap: 1.6rem;
  }

  nav a {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.8125rem;
    letter-spacing: var(--letter-spacing-meta);
    text-transform: uppercase;
    padding: 0.4rem 0;
    color: var(--ink-soft);
    text-decoration: none;
  }

  nav a:hover {
    color: var(--ink);
    text-decoration: none;
  }

  nav a[aria-current="page"],
  nav a[aria-current="page"]:hover {
    color: var(--signal);
    text-decoration: underline;
    text-decoration-color: var(--signal);
    text-decoration-thickness: 2px;
    text-underline-offset: 4px;
  }

  footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 3.2rem;
    padding-top: 1.6rem;
    border-top: 1px solid var(--rule);
    font-family: var(--font-sans);
    font-size: 0.75rem;
    letter-spacing: 0;
    color: var(--ink-soft);
  }

  .feed-links {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .feed-links > span {
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-meta);
  }

  .feed-links a {
    padding: 0.4rem 0;
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-meta);
  }

  footer a {
    color: var(--ink-soft);
    text-decoration: none;
  }

  footer a:hover {
    color: var(--ink);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }
</style>
